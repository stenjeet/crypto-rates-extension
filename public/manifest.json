{
	"manifest_version": 3,
    "name": "Crypto Rates",
    "description": "Easy access to cryptocurrency rates.",
    "version": "1.1.0",
    "action": {
		"default_title": "Exchange Rates",
		"default_popup": "index.html", 
		"default_icon" : {
			"128": "icons/BTC.png"
		}
	},
    "permissions": [
		"scripting",
		"storage",
		"notifications"
	],
	"background": {
		"service_worker": "background.js"
	},
	"web_accessible_resources": [
		{
			"resources": ["css/*"],
			"matches": ["<all_urls>"]
		}
    ],
	"host_permissions": [
		"<all_urls>"
	]
}